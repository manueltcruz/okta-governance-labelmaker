###############################################################################
# Okta LabelMaker – Environment Variable Template
#
# Copy this file to `.env` and replace the placeholder values.
# NEVER commit the real `.env` file.
###############################################################################

# =============================================================================
# General / Runtime
# =============================================================================
NODE_ENV=development
PORT=3001

# =============================================================================
# Frontend (Vite) – variables exposed to the browser
# NOTE: Vite only exposes variables prefixed with VITE_
# =============================================================================

# Okta OIDC issuer (authorization server)
# Example:
# https://dev-123456.okta.com/oauth2/default
VITE_OKTA_ISSUER=https://YOUR_OKTA_DOMAIN/oauth2/YOUR_AUTH_SERVER_ID

# OIDC application (frontend / SPA) client ID
VITE_OKTA_CLIENT_ID=YOUR_FRONTEND_CLIENT_ID

# Redirect URI configured in the Okta OIDC app
# Must match exactly
VITE_OKTA_REDIRECT_URI=http://localhost:5173/login/callback

# OIDC scopes requested by the frontend
VITE_OKTA_SCOPES=openid profile email

# Backend API target used by Vite dev proxy
VITE_API_PROXY_TARGET=http://localhost:3001

# Value needed for Okta Resource Name (ORN). Must be either "okta" or "oktapreview"
VITE_OKTA_PARTITION=oktapreview or okta
# Okta Tenant OrgID needed for Okta Resource Name (ORN). Example: 12345abcde
VITE_OKTA_ORG_ID=


# =============================================================================
# Backend (Express / BFF)
# =============================================================================

# Base Okta org URL (no trailing slash)
# Example:
# https://dev-123456.okta.com
OKTA_ORG_URL=https://YOUR_OKTA_DOMAIN

# Issuer used to verify incoming user access tokens
# Typically the same as VITE_OKTA_ISSUER
OKTA_ISSUER=https://YOUR_OKTA_DOMAIN/oauth2/YOUR_AUTH_SERVER_ID

# Audience expected in incoming access tokens
# Common default: api://default
OKTA_AUDIENCE=api://default

# Client ID used by the backend JWT verifier
# In most setups this matches the frontend OIDC client ID
OKTA_CLIENT_ID=YOUR_FRONTEND_CLIENT_ID

# =============================================================================
# Backend Service App (Client Credentials + Private Key JWT)
# Used for Okta Governance API calls
# =============================================================================

# Service application client ID
BFF_CLIENT_ID=YOUR_SERVICE_APP_CLIENT_ID

# Private key for the service app (single-line JSON)
# IMPORTANT:
# - Must be valid JSON
# - Must be on ONE LINE
# - Do NOT add line breaks
#
# Example (placeholder only):
# {"kty":"RSA","kid":"abc123","use":"sig","alg":"RS256","n":"...","e":"AQAB","d":"..."}
BFF_PRIVATE_KEY={"kty":"RSA","kid":"REPLACE_ME","use":"sig","alg":"RS256","n":"REPLACE_ME","e":"AQAB","d":"REPLACE_ME"}

# =============================================================================
# Optional / Advanced
# =============================================================================

# Log verbosity (if implemented in backend)
# LOG_LEVEL=debug
